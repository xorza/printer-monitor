# Optional: omit both to disable PrusaLink (no pause/resume, no print status)
PRUSALINK_URL=
PRUSALINK_API_KEY=
RTSP_URL=rtsp://prusacam.lan/live

# Optional: detection sensitivity multiplier (default 1.0, range 0.1-5.0)
# DETECTION_SENSITIVITY=1.0

TELEGRAM_BOT_TOKEN=<token>
TELEGRAM_CHAT_ID=<allowed_chat_id>
